<footer class="footer">
  <div class="footer-container container">
    <div class="footer-brand">
      <pre class="yob-art" aria-label="Yob mascot pixel art">
  ▄▄▄
 █o o█
 █ ▄ █
  ▀▀▀</pre>
      <div class="footer-info">
        <a href="/" class="footer-logo">CTRL+WATCH</a>
        <p class="footer-tagline">Your algorithm is broken. We're the fix.</p>
        <p class="footer-copy">© 2025–2026 CTRL+WATCH — All issues are independent publications.</p>
      </div>
    </div>

    <div class="footer-links-section">
      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/" class="footer-link">HOME</a>
        <a href="/archive" class="footer-link">ARCHIVE</a>
        <a href="/about" class="footer-link">ABOUT</a>
        <a href="/rss.xml" class="footer-link" target="_blank" rel="noopener">RSS</a>
      </nav>
