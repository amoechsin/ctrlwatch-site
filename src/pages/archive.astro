---
import BaseLayout from '../layouts/BaseLayout.astro';
import IssueCard from '../components/IssueCard.astro';
import { issues } from '../data/issues.js';
---

<BaseLayout
  title="Archive — CTRL+WATCH Magazine"
  description="All CTRL+WATCH issues from #001 to present. Browse the full archive of YouTube channel reviews."
>
  <section class="archive">
    <div class="container">
      <div class="archive-header">
        <h1 class="archive-title">▶ THE ARCHIVE</h1>
        <p class="archive-subtitle">ALL ISSUES — #001 TO PRESENT</p>
      </div>

      <div class="archive-grid">
        {issues.map((issue, index) => (
          <IssueCard
            slug={issue.slug}
            number={issue.number}
            date={issue.date}
            title={issue.title}
            subtitle={issue.subtitle}
            coverColor={issue.coverColor}
            tag={issue.tag}
            published={issue.published}
            animationDelay={index * 100}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .archive {
    padding: var(--space-xl) 0;
    min-height: 60vh;
  }

  .archive-header {
    margin-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
    padding-bottom: var(--space-lg);
  }

  .archive-title {
    font-size: var(--text-2xl);
    color: var(--text-primary);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
  }

  .archive-subtitle {
    font-family: 'Share Tech Mono', monospace;
    font-size: var(--text-sm);
    color: var(--text-secondary);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .archive-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  @media (max-width: 1024px) {
    .archive-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .archive-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
